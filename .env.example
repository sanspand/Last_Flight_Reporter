# API Configuration
AIRLABS_API_KEY=your_api_key_here
AIRPORT_ICAO=KDAL
AIRLINES_FILTER=WN,DL
FLIGHTS_LIMIT=10

# Email Configuration (set EMAIL_ENABLED to True to enable emails)
EMAIL_ENABLED=False
EMAIL_SENDER=your_email@gmail.com
EMAIL_SENDER_PASSWORD=your_app_specific_password
EMAIL_RECIPIENT=manager@example.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=flights.log
